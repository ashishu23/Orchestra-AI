# ── LLM Providers ──────────────────────────────────────────────────────────────
# Used by: orchestrator
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM provider to use: "google" | "anthropic"
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash

# ── Embedding ──────────────────────────────────────────────────────────────────
# Used by: knowledge-vault
# Same Google key used for text-embedding-004
GOOGLE_API_KEY=your_google_api_key_here

# Embedding provider: "google" | "sentence-transformers"
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=models/gemini-embedding-001

# ── Qdrant ─────────────────────────────────────────────────────────────────────
# Used by: knowledge-vault
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Service URLs (orchestrator needs these) ────────────────────────────────────
VAULT_URL=http://localhost:8001
SANDBOX_URL=http://localhost:8002

# ── Orchestrator tuning ────────────────────────────────────────────────────────
MAX_RETRIES=3
MCP_TIMEOUT=30.0

# ── Sandbox resource limits ────────────────────────────────────────────────────
MAX_CPU_SECONDS=10
MAX_MEMORY_MB=128
TIMEOUT_SECONDS=15
